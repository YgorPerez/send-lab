{
	"name": "send-lab",
	"version": "1.0.0",
	"description": "SEND LAB — 8-Week climbing training console (SvelteKit + TypeScript)",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.5.2",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "pnpm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "pnpm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"typecheck:ts7": "pnpm run paraglide && svelte-kit sync && tsgo --noEmit -p tsconfig.gate.json",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"doctor": "svelte-doctor check",
		"fallow": "fallow dead-code",
		"fallow:health": "fallow health",
		"verify": "pnpm run lint && pnpm run check && pnpm run typecheck:ts7 && pnpm run doctor && pnpm run fallow"
	},
	"dependencies": {
		"better-auth": "^1.6.20",
		"better-sqlite3": "^12.11.1",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@inlang/paraglide-js": "^2.20.0",
		"@lucide/svelte": "^1.21.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^26.0.0",
		"@typescript/native-preview": "7.0.0-dev.20260620.1",
		"drizzle-kit": "^0.31.10",
		"fallow": "^2.101.0",
		"mode-watcher": "^1.1.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-doctor": "^0.3.0",
		"svelte-sonner": "^1.1.1",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.0",
		"vite": "^8.0.16"
	}
}
