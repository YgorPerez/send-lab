# Copy to .env and fill in. BETTER_AUTH_SECRET: openssl rand -base64 33
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:5173

# Turso (libSQL). Leave both unset locally to use a local file DB (file:local.db).
# Production: create a DB with the Turso CLI, then paste its URL + a token.
#   turso db create send-lab
#   turso db show send-lab --url
#   turso db tokens create send-lab
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
